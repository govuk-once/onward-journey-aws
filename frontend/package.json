{
	"name": "govuk-once-onward-journey-frontend",
	"homepage": "https://github.com/govuk-once/onward-journey",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "make prepare || svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"test": "NODE_OPTIONS='--experimental-vm-modules' jest"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.0",
		"@eslint/js": "^9.39.1",
		"@jest/globals": "^30.2.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.48.5",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@types/jest": "^29.5.14",
		"@types/node": "^24",
		"eslint": "^9.39.1",
		"eslint-plugin-svelte": "^3.13.1",
		"globals": "^16.5.0",
		"jest": "^29.7.0",
		"sass": "^1.97.3",
		"svelte": "^5.43.8",
		"svelte-check": "^4.3.4",
		"ts-jest": "^29.2.5",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.48.1",
		"uuid": "^13.0.0",
		"vite": "^7.2.2"
	},
	"license": "MIT",
	"engines": {
		"node": ">= 24",
		"npm": "^11.6.2"
	},
	"dependencies": {
		"govuk-frontend": "^5.14.0",
		"svelte-markdown": "^0.4.1"
	},
	"overrides": {
    "svelte-markdown": {
      "svelte": "$svelte"
    }

}
}
